{
  "name": "my-resume",
  "version": "0.1.0",
  "description": "My resume is a clone of VSCode IDE made using Next.js and Typescript.",
  "author": "Mr. Utzig <lutzig.octavius@gmail.com>",
  "private": true,
  "repository": "https://github.com/mr-utzig/my-resume",
  "license": "MIT",
  "scripts": {
    "start": "next start -p 6060",
    "build:production": "next build --profile",
    "build:debug": "next build --debug",
    "dev": "next dev -p 6060",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "test": "jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "jest --passWithNoTests --runInBand",
    "test:staged": "yarn test --findRelatedTests",
    "test:ci": "yarn test --coverage",
    "prepare": "husky install"
  },
  "dependencies": {
    "@heroicons/react": "^1.0.6",
    "next": "12.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@types/jest": "^28.1.4",
    "@types/node": "18.0.1",
    "@types/react": "18.0.14",
    "@types/react-dom": "18.0.5",
    "autoprefixer": "^10.4.7",
    "eslint": "8.19.0",
    "eslint-config-next": "12.2.0",
    "husky": "^8.0.1",
    "jest": "^28.1.2",
    "jest-environment-jsdom": "^28.1.2",
    "lint-staged": "^13.0.3",
    "postcss": "^8.4.14",
    "tailwindcss": "^3.1.5",
    "ts-jest": "^28.0.5",
    "typescript": "4.7.4"
  }
}
